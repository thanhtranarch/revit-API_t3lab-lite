<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid.Resources>
        <!-- Styles -->
        <Style TargetType="Button" x:Key="FolderButtonStyle">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDC3C7"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
        </Style>
    </Grid.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Folder selection bar -->
            <RowDefinition Height="Auto"/> <!-- Search bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
            <RowDefinition Height="Auto"/> <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- ══════ TITLE BAR ══════ -->
        <Grid Grid.Row="0" x:Name="title_bar_grid" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- T3Lab logo + Title + Subtitle -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Margin="12,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Image x:Name="logo_image" Width="44" Height="44" Margin="0,0,12,0"
                       VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                                   Foreground="#3498DB" VerticalAlignment="Bottom" Margin="0,0,6,1"/>
                        <TextBlock Text="Load Family" FontSize="18" FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                    <Separator Height="1" Background="#BDC3C7" Margin="0,3,0,3"/>
                    <TextBlock Text="Load Revit families from local folders or cloud"
                               FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Minimize -->
                <Button x:Name="btn_minimize_fl"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize">
                    <TextBlock Text="—" FontSize="14" FontWeight="Bold"
                               Foreground="#7F8C8D" Margin="0,-8,0,0"/>
                </Button>
                <!-- Close -->
                <Button x:Name="btn_close_x_fl"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close">
                    <TextBlock Text="✕" FontSize="16" FontWeight="Bold" Foreground="#7F8C8D">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══════ FOLDER SELECTION BAR ══════ -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="Source:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontWeight="SemiBold"/>
                    <RadioButton x:Name="radio_local"
                                 Content="Local"
                                 GroupName="DataSource"
                                 IsChecked="True"
                                 VerticalAlignment="Center"
                                 Margin="0,0,15,0"/>
                    <RadioButton x:Name="radio_cloud"
                                 Content="Cloud (Vercel)"
                                 GroupName="DataSource"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
                </StackPanel>
                <Button x:Name="btn_select_folder"
                        Content="Update Folder"
                        DockPanel.Dock="Left"
                        Style="{StaticResource FolderButtonStyle}"/>
                <TextBlock x:Name="txt_current_folder"
                           Text="No folder selected"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontStyle="Italic"
                           Foreground="#666666"/>
            </DockPanel>
        </Border>

        <!-- ══════ SEARCH BAR ══════ -->
        <Border Grid.Row="2" Padding="10" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="🔍"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Margin="5,0,10,0"/>
                <TextBox x:Name="txt_search"
                         Height="32"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- ══════ MAIN CONTENT ══════ -->
        <DockPanel Grid.Row="3">
            <!-- Category Tree on Left -->
            <Border DockPanel.Dock="Left"
                    Width="250"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,1,0"
                    Background="#FAFAFA">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Categories"
                               FontWeight="Bold"
                               FontSize="14"
                               Padding="10"
                               Background="#E8E8E8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="tree_categories"
                                  Padding="5"
                                  BorderThickness="0"
                                  Background="Transparent">
                        </TreeView>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Family Grid on Right -->
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="#E8E8E8"
                        Padding="10"
                        BorderBrush="#D0D0D0"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock x:Name="txt_result_count"
                                   Text="0 families found"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right">
                            <Button x:Name="btn_select_all"
                                    Content="Select All"
                                    Style="{StaticResource FolderButtonStyle}"
                                    Margin="5,0"
                                    Padding="8,4"/>
                            <Button x:Name="btn_select_none"
                                    Content="Select None"
                                    Style="{StaticResource FolderButtonStyle}"
                                    Background="#7F8C8D"
                                    Padding="8,4"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10">
                    <ItemsControl x:Name="items_families">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D0D0D0"
                                        BorderThickness="1"
                                        Padding="8"
                                        Margin="5"
                                        Width="140"
                                        Height="180"
                                        Background="White">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <CheckBox x:Name="chk_family"
                                                  IsChecked="{Binding IsChecked}"
                                                  HorizontalAlignment="Left"
                                                  Margin="0,0,0,4"/>
                                        <!-- Thumbnail area with grey placeholder -->
                                        <Border Height="90" Background="#F0F0F0"
                                                BorderBrush="#E0E0E0" BorderThickness="1"
                                                Margin="0,2">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   MaxHeight="40"
                                                   ToolTip="{Binding FullPath}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </DockPanel>

        <!-- ══════ ACTION BUTTONS ══════ -->
        <Border Grid.Row="4"
                Background="#F0F0F0"
                Padding="15"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="txt_selected_count"
                               Text="0 families selected"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"
                               FontWeight="SemiBold"/>
                    <Button x:Name="btn_load"
                            Content="Load"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#3498DB"
                            Foreground="White"
                            Margin="5,0"
                            IsEnabled="False"/>
                    <Button x:Name="btn_cancel"
                            Content="Cancel"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#ECF0F1"
                            Foreground="#2C3E50"
                            BorderBrush="#BDC3C7"
                            BorderThickness="1"
                            Margin="5,0"/>
                </StackPanel>
                <!-- Copyright -->
                <TextBlock Text="&#169; Copyright by T3Lab"
                           FontSize="10" Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Grid>
