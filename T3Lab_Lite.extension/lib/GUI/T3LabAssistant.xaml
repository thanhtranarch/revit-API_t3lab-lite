<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T3Lab Assistant"
        Width="480" Height="660"
        MinWidth="400" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="#F4F6F9">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Send button -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0,6,6,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#93C5FD"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Window chrome buttons -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                </Trigger>
            </Style.Triggers>
            <Style.Setters>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E74C3C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style.Setters>
        </Style>

        <!-- Quick-tool chip button -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Divider -->
            <RowDefinition Height="Auto"/>
            <!-- Quick tools -->
            <RowDefinition Height="*"/>
            <!-- Chat -->
            <RowDefinition Height="Auto"/>
            <!-- Input bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#2563EB" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="14,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Border Background="#FFFFFF22" CornerRadius="8" Width="38" Height="38"
                        Margin="0,0,10,0">
                    <Image x:Name="logo_image" Width="28" Height="28"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="T3Lab" FontSize="17" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text=" Assistant" FontSize="17" FontWeight="Light"
                                   Foreground="#93C5FD" VerticalAlignment="Center"/>
                        <!-- AI badge -->
                        <Border x:Name="ai_status_badge"
                                Background="#16A34A" CornerRadius="4"
                                Padding="5,1" Margin="8,0,0,0"
                                Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock x:Name="ai_status_text" Text="AI"
                                       FontSize="9" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Chatbox thực thi nhanh T3Lab Tools" FontSize="10"
                               Foreground="#93C5FD" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Window controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="0,0,6,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource ChromeBtn}"
                        ToolTip="Minimize" Click="minimize_clicked">
                    <TextBlock Text="&#x2013;" FontSize="16" Foreground="White" Margin="0,-4,0,0"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseBtn}"
                        ToolTip="Close" Click="close_clicked">
                    <TextBlock Text="&#x2715;" FontSize="13" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Thin accent line -->
        <Border Grid.Row="1" Height="3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2563EB" Offset="0"/>
                    <GradientStop Color="#38BDF8" Offset="0.5"/>
                    <GradientStop Color="#34D399" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             QUICK TOOLS
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Padding="14,10,14,10">
            <StackPanel>
                <TextBlock Text="CÔNG CỤ NHANH" FontSize="9.5" FontWeight="Bold"
                           Foreground="#9CA3AF" Margin="0,0,0,8"/>
                <WrapPanel>
                    <Button x:Name="btn_batchout" Style="{StaticResource ChipBtn}"
                            Click="tool_batchout_clicked"
                            ToolTip="Xuất sheet hàng loạt sang PDF, DWG, DWF...">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E4;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="BatchOut" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_parasync" Style="{StaticResource ChipBtn}"
                            Click="tool_parasync_clicked"
                            ToolTip="Đồng bộ parameters giữa các model">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F504;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ParaSync" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_loadfamily" Style="{StaticResource ChipBtn}"
                            Click="tool_loadfamily_clicked"
                            ToolTip="Load family từ thư mục vào project">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C2;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Load Family" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_projectname" Style="{StaticResource ChipBtn}"
                            Click="tool_projectname_clicked"
                            ToolTip="Đặt tên project">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F3F7;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Project Name" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_workset" Style="{StaticResource ChipBtn}"
                            Click="tool_workset_clicked"
                            ToolTip="Quản lý worksets">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F5C2;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Workset" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_dimtext" Style="{StaticResource ChipBtn}"
                            Click="tool_dimtext_clicked"
                            ToolTip="Sửa text trong dimensions (cần chọn dimension trước)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CF;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dim Text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             CHAT AREA
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3" x:Name="chat_scroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F4F6F9"
                      Padding="12,10,12,6">
            <StackPanel x:Name="chat_history_panel" Margin="0,0,0,4">

                <!-- Welcome bubble -->
                <Grid Margin="0,0,48,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                            Margin="0,2,8,0" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#38BDF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="T3" FontSize="11" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Bubble -->
                    <Border Grid.Column="1" Background="White" CornerRadius="4,12,12,12"
                            Padding="12,10" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="T3Lab Assistant" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#2563EB" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#374151"
                                       LineHeight="18"
                                       Text="Xin chào! Tôi có thể giúp bạn thực hiện nhanh các công cụ T3Lab."/>
                            <Border Background="#F0F9FF" CornerRadius="6" Padding="8,6" Margin="0,8,0,0"
                                    BorderBrush="#BAE6FD" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="10" Foreground="#0369A1" FontWeight="SemiBold"
                                               Margin="0,0,0,3" Text="Ví dụ lệnh:"/>
                                    <TextBlock FontSize="11" Foreground="#0284C7" TextWrapping="Wrap"
                                               Text="&#x2022;  mở batchout  &#x2022;  xuất sheet PDF  &#x2022;  parasync&#x0A;&#x2022;  load family  &#x2022;  workset  &#x2022;  dim text"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════
             INPUT BAR
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input container -->
                <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1"
                        CornerRadius="6,0,0,6" Background="White">
                    <TextBox x:Name="chat_input"
                             Height="36"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="12.5"
                             Foreground="#111827"
                             CaretBrush="#2563EB"
                             ToolTip="Nhập lệnh Tiếng Việt hoặc English (Enter để gửi)"
                             KeyDown="input_keydown"/>
                </Border>

                <!-- Send button -->
                <Button Grid.Column="1" x:Name="send_button"
                        Height="36"
                        Style="{StaticResource SendButton}"
                        Click="send_clicked"
                        ToolTip="Gửi (Enter)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Gửi" VerticalAlignment="Center"/>
                        <TextBlock Text=" &#x27A4;" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
