<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T3Lab Assistant"
        Width="560" Height="720"
        MinWidth="480" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="80"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Section header label ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="0,10,0,5"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- ── Primary (blue) button — matches BatchOut PrimaryButton ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="15,8"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Window control buttons — matches BatchOut WindowControlButton ── -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Close button — red on hover ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Quick-tool chip — secondary button style ── -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="#ECF0F1"/>
            <Setter Property="Foreground"      Value="#2C3E50"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDC3C7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D5DBDB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C8D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"   Value="#F5F5F5"/>
                                <Setter TargetName="bd" Property="BorderBrush"  Value="#DCDCDC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>   <!-- Header             -->
            <RowDefinition Height="1"/>    <!-- Separator          -->
            <RowDefinition Height="Auto"/> <!-- Quick tools        -->
            <RowDefinition Height="1"/>    <!-- Separator          -->
            <RowDefinition Height="*"/>    <!-- Chat area          -->
            <RowDefinition Height="Auto"/> <!-- Input bar          -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER  (white, same layout as BatchOut)
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Margin="15,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Image x:Name="logo_image" Width="60" Height="60" Margin="0,0,15,0"/>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="T3Lab" FontSize="22" FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                        <TextBlock Text=" Assistant" FontSize="22" FontWeight="Bold"
                                   Foreground="#3498DB"/>
                        <!-- AI / LOCAL badge -->
                        <Border x:Name="ai_status_badge"
                                Background="#27AE60" CornerRadius="3"
                                Padding="6,2" Margin="8,2,0,0"
                                Visibility="Collapsed" VerticalAlignment="Center"
                                ToolTip="AI engine status">
                            <TextBlock x:Name="ai_status_text" Text="LOCAL"
                                       FontSize="9" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <Separator Height="1" Background="#BDC3C7" Margin="0,4,0,4"/>
                    <TextBlock Text="Chatbox AI cho T3Lab Tools"
                               FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <!-- Window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_reset_chat"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Làm mới / Reset cuộc trò chuyện"
                        Click="reset_chat_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↺" FontSize="16" FontWeight="Bold"
                               Foreground="#7F8C8D" ToolTip="Reset chat"/>
                </Button>
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize" Click="minimize_clicked">
                    <TextBlock Text="—" FontSize="14" FontWeight="Bold"
                               Foreground="#7F8C8D" Margin="0,-8,0,0"/>
                </Button>
                <Button x:Name="btn_close"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_clicked">
                    <TextBlock Text="✕" FontSize="13" Foreground="#7F8C8D"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header separator -->
        <Border Grid.Row="1" Background="#BDC3C7"/>

        <!-- ═══════════════════════════════════════════════════════════
             QUICK TOOLS
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White" Padding="15,10,15,10">
            <StackPanel>
                <TextBlock Text="CÔNG CỤ NHANH" FontSize="11" FontWeight="Bold"
                           Foreground="#7F8C8D" Margin="0,0,0,8"/>
                <WrapPanel>
                    <Button x:Name="btn_batchout" Style="{StaticResource ChipBtn}"
                            Click="tool_batchout_clicked"
                            ToolTip="Xuất sheet hàng loạt sang PDF, DWG, DWF...">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E4;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="BatchOut" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_parasync" Style="{StaticResource ChipBtn}"
                            Click="tool_parasync_clicked"
                            ToolTip="Đồng bộ parameters giữa các model">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F504;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ParaSync" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_loadfamily" Style="{StaticResource ChipBtn}"
                            Click="tool_loadfamily_clicked"
                            ToolTip="Load family từ thư mục vào project">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C2;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Load Family" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_projectname" Style="{StaticResource ChipBtn}"
                            Click="tool_projectname_clicked"
                            ToolTip="Đặt tên project">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F3F7;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Project Name" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_workset" Style="{StaticResource ChipBtn}"
                            Click="tool_workset_clicked"
                            ToolTip="Quản lý worksets">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F5C2;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Workset" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btn_dimtext" Style="{StaticResource ChipBtn}"
                            Click="tool_dimtext_clicked"
                            ToolTip="Sửa text trong dimensions">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CF;" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dim Text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Quick-tools separator -->
        <Border Grid.Row="3" Background="#BDC3C7"/>

        <!-- ═══════════════════════════════════════════════════════════
             CHAT AREA
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="4" x:Name="chat_scroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F8F9FA"
                      Padding="15,12,15,8">
            <StackPanel x:Name="chat_history_panel" Margin="0,0,0,4">

                <!-- Welcome bubble -->
                <Grid Margin="0,0,60,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="36" Height="36"
                            CornerRadius="18" Background="#3498DB"
                            Margin="0,2,10,0" VerticalAlignment="Top">
                        <TextBlock Text="T3" FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Bubble -->
                    <Border Grid.Column="1" Background="White"
                            CornerRadius="3,8,8,8"
                            Padding="14,10"
                            BorderBrush="#BDC3C7" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="T3Lab Assistant" FontSize="10" FontWeight="Bold"
                                       Foreground="#3498DB" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#2C3E50"
                                       LineHeight="20"
                                       Text="Xin chào! Tôi là T3Lab Assistant. Tôi có thể giúp bạn:"/>
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock FontSize="12" Foreground="#7F8C8D"
                                           Text="&#x2022;  Mở BatchOut và xuất sheet"/>
                                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"
                                           Text="&#x2022;  Chạy ParaSync, LoadFamily, và các công cụ khác"/>
                                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"
                                           Text="&#x2022;  Trả lời câu hỏi về T3Lab"/>
                            </StackPanel>
                            <Separator Height="1" Background="#ECF0F1" Margin="0,8,0,6"/>
                            <TextBlock FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"
                                       Text="Nhập lệnh bằng Tiếng Việt hoặc English."/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════
             INPUT BAR
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="White"
                BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input field -->
                <Border Grid.Column="0"
                        BorderBrush="#BDC3C7" BorderThickness="1,1,0,1"
                        CornerRadius="3,0,0,3" Background="White">
                    <TextBox x:Name="chat_input"
                             Height="36"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="13"
                             Foreground="#2C3E50"
                             CaretBrush="#3498DB"
                             ToolTip="Nhập lệnh Tiếng Việt hoặc English (Enter để gửi)"
                             KeyDown="input_keydown"/>
                </Border>

                <!-- Send button (PrimaryButton style) -->
                <Button Grid.Column="1" x:Name="send_button"
                        Height="36"
                        Style="{StaticResource PrimaryButton}"
                        Padding="18,0"
                        Click="send_clicked"
                        ToolTip="Gửi (Enter)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Gửi" VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock Text=" &#x27A4;" FontSize="11" VerticalAlignment="Center"
                                   Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
