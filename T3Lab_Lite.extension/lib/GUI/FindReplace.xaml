<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Views: Find and Replace"
    Height="240" Width="380"
    WindowStartupLocation="CenterScreen"
    HorizontalAlignment="Center"
    ShowInTaskbar="True"
    WindowStyle="None"
    ResizeMode="NoResize"
    Background="White"
    FontFamily="Segoe UI">



    <!--MAIN-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!--HEADER START (BatchOut style)-->
        <Grid MouseDown="header_drag" Background="#F8F9FA"
              BorderBrush="#BDC3C7" BorderThickness="0,0,0,1"
              Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="✏️" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="main_title" Text="Find and Replace"
                           FontWeight="SemiBold" Foreground="#2C3E50"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕" Grid.Column="1"
                    Width="30" Height="25" FontSize="11"
                    Click="button_close"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#7F8C8D" Cursor="Hand"
                    VerticalAlignment="Center" Margin="0,0,4,0"/>
        </Grid>
        <!--HEADER END-->

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="15*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>


                <StackPanel Grid.Column="0"
                                    Margin="5" >
                    <Label x:Name="UI_label"
                        Content="ViewName"
                           Margin="0,-25,0,0"
                           Foreground="#7F8C8D"/>
                    <Border Height="130"
                            BorderBrush="#BDC3C7"
                            BorderThickness="1" CornerRadius="4"
                            HorizontalAlignment="Stretch" Width="Auto">



                        <StackPanel Grid.Row="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Margin="10">

                            <!--FIND-->
                            <DockPanel  HorizontalAlignment="Left"
                                        Margin="2">
                                <TextBlock Text="Find:"
                                            Foreground="#2C3E50"
                                            Width="60"/>

                                <TextBox x:Name="input_find"
                                         Width="200"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Background="White"
                                         Foreground="#2C3E50"/>
                            </DockPanel>

                            <!--REPLACE-->
                            <DockPanel HorizontalAlignment="Left"
                                       Margin="2">

                                <TextBlock  Text="Replace:"
                                            Foreground="#2C3E50"
                                            Width="60"/>

                                <TextBox x:Name="input_replace"
                                            Width="200"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource header_background}"
                                            Foreground="#2C3E50"/>
                            </DockPanel>

                            <!--PREFIX-->
                            <DockPanel HorizontalAlignment="Left"
                                        Margin="2">
                                <TextBlock Text="Prefix:"
                                           Foreground="#2C3E50"
                                           Width="60"/>

                                <TextBox x:Name="input_prefix"
                                         Width="200"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Background="White"
                                         Foreground="#2C3E50"/>
                            </DockPanel>

                            <!--SUFFIX-->
                            <DockPanel HorizontalAlignment="Left"
                                        Margin="2">
                                <TextBlock Text="Suffix:"
                                           Foreground="#2C3E50"
                                           Width="60"/>

                                <TextBox x:Name="input_suffix"
                                         Width="200"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Background="White"
                                         Foreground="#2C3E50"/>
                            </DockPanel>

                        </StackPanel>
                    </Border>

                    <Button x:Name="UI_main_button"
                        Click="button_run"
                            Content="Rename"
                            Margin="0,10,0,0"
                            Width="75"
                            Height="25"/>
                    <!-- Copyright -->
                    <TextBlock Text="© Copyright by T3Lab"
                               FontSize="9" Foreground="#AAAAAA"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>