<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Property Line Tool - Lightbox API"
        Width="700" Height="1020"
        MinWidth="620" MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="White"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Primary button style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success button style -->
        <Style x:Key="SuccessBtn" TargetType="Button">
            <Setter Property="Background" Value="#107C10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0E6B0E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input field style -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox style -->
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- GroupBox style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content (scrollable) -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
            <RowDefinition Height="Auto"/>  <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ HEADER -->
        <Border Grid.Row="0" Background="#12122A" Padding="20,14"
                MouseLeftButtonDown="header_drag" Cursor="SizeAll">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="btn_close_x" Content="✕"
                            Width="30" Height="30"
                            Style="{StaticResource SecondaryBtn}"
                            Click="btn_close_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4CD;" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Property Line Tool" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Powered by Lightbox RE API" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- API KEY SECTION -->
                <GroupBox Header=" API Configuration">
                    <StackPanel>
                        <TextBlock Text="Lightbox API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txt_api_key"
                                     Grid.Column="0"
                                     Style="{StaticResource InputField}"
                                     ToolTip="Enter your Lightbox RE API key. Get one at https://lightboxre.com"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="btn_save_key"
                                    Grid.Column="1"
                                    Content="Save"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="btn_save_key_Click"/>
                        </Grid>
                        <TextBlock x:Name="txt_api_status"
                                   Text="No API key configured"
                                   Foreground="#FF6B6B"
                                   FontSize="11"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- ADDRESS SEARCH SECTION -->
                <GroupBox Header=" Search Property by Address">
                    <StackPanel>
                        <TextBlock Text="US Property Address" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txt_address"
                                     Grid.Column="0"
                                     Style="{StaticResource InputField}"
                                     KeyDown="txt_address_KeyDown"
                                     ToolTip="e.g. 123 Main St, Los Angeles, CA 90001"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="btn_search"
                                    Grid.Column="1"
                                    Content="Search"
                                    MinWidth="80"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="btn_search_Click"/>
                        </Grid>
                        <TextBlock Text="Examples: 350 Fifth Ave, New York NY | 1600 Pennsylvania Ave NW, Washington DC"
                                   Foreground="#666" FontSize="10" FontStyle="Italic"/>
                    </StackPanel>
                </GroupBox>

                <!-- SEARCH RESULTS -->
                <GroupBox Header=" Search Results">
                    <StackPanel>
                        <Border x:Name="border_no_results"
                                Background="#2D2D44" CornerRadius="4" Padding="16"
                                Margin="0,0,0,8">
                            <TextBlock Text="Enter an address above and click Search to find parcels"
                                       Foreground="#666" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                        </Border>

                        <ListView x:Name="lv_parcels"
                                  Background="#2D2D44"
                                  BorderBrush="#444"
                                  BorderThickness="1"
                                  Foreground="White"
                                  MaxHeight="200"
                                  Visibility="Collapsed"
                                  SelectionChanged="lv_parcels_SelectionChanged">
                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D5C"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#0078D4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Resources>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address" Width="280"
                                                    DisplayMemberBinding="{Binding display_address}"/>
                                    <GridViewColumn Header="Parcel ID" Width="140"
                                                    DisplayMemberBinding="{Binding parcel_id}"/>
                                    <GridViewColumn Header="Area (sqft)" Width="100"
                                                    DisplayMemberBinding="{Binding area_sqft}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </GroupBox>

                <!-- SELECTED PARCEL DETAILS -->
                <GroupBox x:Name="grp_parcel_details"
                          Header=" Selected Parcel Details"
                          Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Parcel ID (APN)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_id" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_address" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="County" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_county" Foreground="White" Margin="0,0,0,10"/>

                            <TextBlock Text="Zoning Code" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_zoning" Foreground="#FFC53D" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Area" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_area" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="Coordinates (Vertices)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_vertices" Foreground="#CCC" Margin="0,0,0,10"/>

                            <TextBlock Text="State" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_state" Foreground="White" Margin="0,0,0,10"/>

                            <TextBlock Text="Flood Zone (FEMA)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_flood" Foreground="#CCC" Margin="0,0,0,10"/>
                        </StackPanel>

                        <!-- Full-width bottom row: Legal Description + Land Use + Map button -->
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Margin="0,130,0,0">
                            <TextBlock Text="Legal Description" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_legal"
                                       Foreground="White" Margin="0,0,0,10"
                                       TextWrapping="Wrap" FontSize="11"/>

                            <TextBlock Text="Land Use" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_land_use" Foreground="#CCC" Margin="0,0,0,12"/>

                            <Button x:Name="btn_download_map"
                                    Content="🗺  Download Parcel Map (OpenStreetMap)"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="btn_download_map_Click"
                                    ToolTip="Fetches OSM map tiles, overlays the parcel boundary in red, and opens the PNG."/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- PROJECT DATA PREVIEW -->
                <GroupBox x:Name="grp_project_data"
                          Header=" Project Data"
                          Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Auto-generated from parcel data. Enter setbacks, construction type, and stories manually."
                                   Foreground="#666" FontSize="10" FontStyle="Italic" Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <Border Background="#12122A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                            <TextBlock x:Name="txt_project_data"
                                       Foreground="#D4D4D4"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Button x:Name="btn_copy_project_data"
                                Content="Copy to Clipboard"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btn_copy_project_data_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- SETBACK LINES SECTION -->
                <GroupBox x:Name="grp_setback"
                          Header=" Setback Lines"
                          Visibility="Collapsed">
                    <StackPanel>

                        <!-- Fetch button + status -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txt_zoning_status"
                                       Grid.Column="0"
                                       Text="Click 'Read Zoning' to load the zoning code from parcel data. Enter setback distances manually."
                                       Foreground="#888"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button x:Name="btn_fetch_zoning"
                                    Grid.Column="1"
                                    Content="Read Zoning"
                                    MinWidth="110"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="btn_fetch_zoning_Click"/>
                        </Grid>

                        <!-- Three setback fields -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Front Setback (ft)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txt_setback_front"
                                         Text=""
                                         Style="{StaticResource InputField}"
                                         ToolTip="Setback from front property line (street side)"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Rear Setback (ft)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txt_setback_rear"
                                         Text=""
                                         Style="{StaticResource InputField}"
                                         ToolTip="Setback from rear property line"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Side Setback (ft)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txt_setback_side"
                                         Text=""
                                         Style="{StaticResource InputField}"
                                         ToolTip="Setback from each side property line"/>
                            </StackPanel>
                        </Grid>

                        <!-- Draw checkbox -->
                        <CheckBox x:Name="chk_draw_setback"
                                  Content="Draw setback envelope when creating property lines"
                                  Foreground="White"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Draws an inset polygon (minimum setback) as Model Lines — representing the buildable area."
                                   Foreground="#666" FontSize="10" FontStyle="Italic"
                                   Margin="20,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- CREATE OPTIONS -->
                <GroupBox Header=" Revit Creation Options">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Elevation (ft)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txt_elevation"
                                     Text="0.0"
                                     Style="{StaticResource InputField}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Line Category" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmb_line_type"
                                      Background="#2D2D44"
                                      Foreground="White"
                                      BorderBrush="#444"
                                      Padding="6,5">
                                <ComboBoxItem Content="Property Lines" IsSelected="True"/>
                                <ComboBoxItem Content="Model Lines"/>
                                <ComboBoxItem Content="Detail Lines"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Origin" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmb_origin"
                                      Background="#2D2D44"
                                      Foreground="White"
                                      BorderBrush="#444"
                                      Padding="6,5">
                                <ComboBoxItem Content="Project Base Point" IsSelected="True"/>
                                <ComboBoxItem Content="Survey Point"/>
                                <ComboBoxItem Content="World Origin (0,0,0)"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════ STATUS BAR -->
        <Border Grid.Row="2" Background="#12122A" Padding="16,8">
            <DockPanel>
                <TextBlock x:Name="txt_status"
                           Text="Ready. Enter an address to begin."
                           Foreground="#888"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Ellipse x:Name="dot_status"
                             Width="8" Height="8"
                             Fill="#888"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="txt_status_label"
                               Text="Idle"
                               Foreground="#888"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ ACTION BUTTONS -->
        <Border Grid.Row="3" Background="#1A1A2E" Padding="16,12">
            <DockPanel>
                <Button x:Name="btn_cancel"
                        DockPanel.Dock="Right"
                        Content="Close"
                        MinWidth="90"
                        Style="{StaticResource SecondaryBtn}"
                        Click="btn_close_Click"/>
                <Button x:Name="btn_create"
                        Content="Create Property Lines in Revit"
                        Style="{StaticResource SuccessBtn}"
                        IsEnabled="False"
                        Margin="0,0,10,0"
                        Click="btn_create_Click"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
