п»ї<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T3Lab - Bulk Family Export"
        Width="1100" Height="680"
        MinWidth="860" MinHeight="500"
        Background="White"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- PRIMARY BUTTON - blue, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - light gray, dark text -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECF0F1"/>
            <Setter Property="Foreground"      Value="#2C3E50"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDC3C7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5DBDB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON - green -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON - red on hover -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>       <!-- Title bar -->
            <RowDefinition Height="Auto"/>     <!-- Configuration -->
            <RowDefinition Height="Auto"/>     <!-- Info tip -->
            <RowDefinition Height="*"/>        <!-- DataGrid -->
            <RowDefinition Height="Auto"/>     <!-- Action bar -->
            <RowDefinition Height="Auto"/>     <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ TITLE BAR ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Grid Grid.Row="0" Height="64" Background="White">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Image x:Name="logo_image" Width="40" Height="40" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold" Foreground="#3498DB"
                                   VerticalAlignment="Bottom" Margin="0,0,6,0"/>
                        <TextBlock Text="Bulk Family Export" FontSize="17" FontWeight="Bold"
                                   Foreground="#2C3E50" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <Separator Height="1" Background="#BDC3C7" Margin="0,3"/>
                    <TextBlock Text="Export CAD blocks as individual Revit families"
                               FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                        Click="minimize_button_clicked" ToolTip="Minimize">
                    <TextBlock Text="&#x2500;" FontSize="12" Foreground="#7F8C8D"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                        Click="maximize_button_clicked" ToolTip="Maximize">
                    <TextBlock Text="&#x25A1;" FontSize="14" Foreground="#7F8C8D"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        Click="close_button_clicked" ToolTip="Close">
                    <TextBlock Text="&#x2715;" FontSize="12" Foreground="#7F8C8D"/>
                </Button>
            </StackPanel>

            <Border Height="1" VerticalAlignment="Bottom" Background="#BDC3C7"/>
        </Grid>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ CONFIGURATION ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- CAD Type -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CAD Type:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="cad_file_combo" Grid.Row="0" Grid.Column="1"
                          FontFamily="Segoe UI" FontSize="12" Padding="6,4" Margin="0,0,8,0"/>
                <Button Content="Scan Blocks" Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource PrimaryButton}" Click="scan_blocks_clicked"/>

                <!-- Discipline -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Discipline:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="discipline_combo" Grid.Row="2" Grid.Column="1"
                          Grid.ColumnSpan="2" FontFamily="Segoe UI" FontSize="12" Padding="6,4"/>

                <!-- Category -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Category:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="category_combo" Grid.Row="4" Grid.Column="1"
                          Grid.ColumnSpan="2" FontFamily="Segoe UI" FontSize="12" Padding="6,4"/>

                <!-- Geometry Mode -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Geometry:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2">
                    <RadioButton x:Name="rb_3d_solid" Content=" 3D Solid / Extrusion" IsChecked="True"
                                 VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#2C3E50" FontFamily="Segoe UI" FontSize="12"/>
                    <RadioButton x:Name="rb_2d_lines" Content=" 2D Model Lines Only"
                                 VerticalAlignment="Center" Foreground="#2C3E50" FontFamily="Segoe UI" FontSize="12"/>
                </StackPanel>

                <!-- Output Folder -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Output:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <TextBox x:Name="output_path" Grid.Row="8" Grid.Column="1"
                         IsReadOnly="True" FontFamily="Segoe UI" FontSize="12"
                         Padding="6,4" Margin="0,0,8,0" Background="#FAFAFA"
                         BorderBrush="#BDC3C7"/>
                <Button Content="Browse..." Grid.Row="8" Grid.Column="2"
                        Style="{StaticResource SecondaryButton}" Click="browse_folder_clicked"/>
            </Grid>
        </Border>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ INFO TIP ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Border Grid.Row="2" Margin="16,10,16,0" BorderBrush="#3498DB" BorderThickness="1"
                Background="#E8F4F8" CornerRadius="2" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tip:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,5,0"/>
                <TextBlock Foreground="#2C3E50" TextWrapping="Wrap"
                           Text="Select a CAD file and click 'Scan Blocks' to discover block references. Use 'Load to Project' to also load exported families into the current model."/>
            </StackPanel>
        </Border>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ DATAGRID ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <DataGrid x:Name="blocks_grid" Grid.Row="3" Margin="16,10,16,0"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  AlternatingRowBackground="#FAFAFA" FontFamily="Segoe UI" FontSize="12"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#ECF0F1" SelectionMode="Single"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="#ECF0F1"/>
                    <Setter Property="Foreground"      Value="#2C3E50"/>
                    <Setter Property="FontWeight"      Value="SemiBold"/>
                    <Setter Property="Padding"         Value="8,6"/>
                    <Setter Property="BorderBrush"     Value="#BDC3C7"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Height"          Value="34"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EBF5FB"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D6EAF8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Select -->
                <DataGridTemplateColumn Header="&#x2713;" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Identity -->
                <DataGridTextColumn Header="Block Name"   Binding="{Binding BlockName}"    Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Layer/Level"  Binding="{Binding LayerLevel}"   Width="110" IsReadOnly="True"/>

                <!-- Counts -->
                <DataGridTextColumn Header="Curves"    Binding="{Binding CurveCount}"    Width="60" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Instances" Binding="{Binding InstanceCount}" Width="70" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Category Details -->
                <DataGridTextColumn Header="Width (mm)" Binding="{Binding WidthMM}" Width="82" IsReadOnly="True">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/><Setter Property="Foreground" Value="#2C3E50"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Depth (mm)" Binding="{Binding DepthMM}" Width="82" IsReadOnly="True">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/><Setter Property="Foreground" Value="#2C3E50"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Arcs" Binding="{Binding ArcCount}" Width="52" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#7F8C8D"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Suggested" Binding="{Binding SuggestedCat}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#2980B9"/><Setter Property="FontStyle" Value="Italic"/><Setter Property="Padding" Value="4,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ ACTION BAR ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Border Grid.Row="4" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                            Click="select_all_clicked" Margin="0,0,8,0"/>
                    <Button Content="Deselect All" Style="{StaticResource SecondaryButton}"
                            Click="deselect_all_clicked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="chk_load_to_project"
                              Content="Load to Project"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"
                              Foreground="#2C3E50"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              ToolTip="After export, load each family into the current Revit project"/>
                    <Button x:Name="btn_export" Content="Export Selected"
                            Style="{StaticResource SuccessButton}" Click="export_clicked"
                            Padding="20,8" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ STATUS BAR ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <Border Grid.Row="5" Background="#FAFAFA" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="status_text" Grid.Column="0" FontSize="11"
                           Foreground="#7F8C8D" Text="Ready"/>
                <TextBlock x:Name="block_count_text" Grid.Column="1" FontSize="11"
                           Foreground="#BDC3C7" Text="0 blocks found"/>
            </Grid>
        </Border>
    </Grid>
</Window>

