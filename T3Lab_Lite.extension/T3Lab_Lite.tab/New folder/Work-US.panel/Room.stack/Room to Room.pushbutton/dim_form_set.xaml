<Window x:Class="YourNamespace.YourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Text Fields" Height="200" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Text Fields" FontSize="14" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <Label Content="Above:" />
                <TextBox />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Prefix:" />
                <TextBox />
                <Label Content="Value:" />
                <TextBox Text="13000" />
                <Label Content="Suffix:" />
                <TextBox />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Below:" />
                <TextBox Text="(E)" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Segment Dimension Leader Visibility:" />
                <ComboBox SelectedItem="By Element">
                    </ComboBox>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Set" />
            <Button Content="Set Default" />
            <Button Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>

