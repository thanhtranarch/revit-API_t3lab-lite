<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Autodesk Family" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Thanh tìm kiếm -->
        <TextBox Grid.Row="0" Margin="10" Height="30" Name="searchBox"/>
        <DockPanel Grid.Row="1">
            <!-- Danh mục bên trái -->
            <TreeView Width="200" Margin="10" Name="categoryTree">
                <TreeViewItem Header="All Results"/>
                <TreeViewItem Header="Casework">
                    <TreeViewItem Header="Base Cabinets"/>
                    <TreeViewItem Header="Counter Tops"/>
                    <TreeViewItem Header="Shelving"/>
                    <TreeViewItem Header="Tall Cabinets"/>
                    <TreeViewItem Header="Wall Cabinets"/>
                </TreeViewItem>
            </TreeView>

            <!-- Danh sách Family -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <WrapPanel Name="familyList">
                    <!-- Nội dung Family sẽ được load bằng Python -->
                </WrapPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Nút Load và Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Load" Width="80" Name="loadButton" Click="OnLoadClick"/>
            <Button Content="Cancel" Width="80" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
