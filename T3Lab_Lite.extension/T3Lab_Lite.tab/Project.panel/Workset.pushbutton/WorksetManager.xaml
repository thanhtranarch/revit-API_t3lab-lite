<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Workset Manager"
    Height="640" Width="1000"
    MinHeight="420" MinWidth="720"
    WindowStartupLocation="CenterScreen"
    Closing="window_closing">

    <DockPanel LastChildFill="True">

        <!-- ====== HEADER ====== -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Workset Manager" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="doc_name" Foreground="#95A5A6" FontSize="11"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
            </StackPanel>
        </Border>

        <!-- ====== STATUS BAR ====== -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5"
                BorderBrush="#DCDCDC" BorderThickness="0,1,0,0" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="status_text" Text="Ready" FontSize="11"
                           Foreground="#555" VerticalAlignment="Center"/>
                <Rectangle Width="1" Fill="#CCC" Margin="12,2"/>
                <TextBlock x:Name="workset_count" Text="" FontSize="11"
                           Foreground="#888" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ====== TOOLBAR ====== -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel>

                <!-- Rule CRUD -->
                <Button x:Name="btn_add" Content="+ Add" Click="btn_add_click"
                        Background="#2980B9" Foreground="White" BorderBrush="#2980B9"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Add a new rule"/>
                <Button x:Name="btn_delete" Content="Delete" Click="btn_delete_click"
                        Background="#C0392B" Foreground="White" BorderBrush="#C0392B"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Delete selected rule(s)"/>
                <Button x:Name="btn_duplicate" Content="Duplicate" Click="btn_duplicate_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Duplicate selected rule"/>
                <Button x:Name="btn_move_up" Content="Up" Click="btn_move_up_click"
                        Padding="8,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Move selected rule up"/>
                <Button x:Name="btn_move_down" Content="Down" Click="btn_move_down_click"
                        Padding="8,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Move selected rule down"/>

                <Rectangle Width="1" Fill="#DCDCDC" Margin="8,2"/>

                <!-- Apply -->
                <Button x:Name="btn_apply_view" Content="Apply to View" Click="btn_apply_view_click"
                        Background="#27AE60" Foreground="White" BorderBrush="#27AE60"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Assign elements in the active view per enabled rules"/>
                <Button x:Name="btn_apply_project" Content="Apply to Project" Click="btn_apply_project_click"
                        Background="#1E8449" Foreground="White" BorderBrush="#1E8449"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Assign ALL project elements per enabled rules"/>

                <Rectangle Width="1" Fill="#DCDCDC" Margin="8,2"/>

                <!-- Workset ops -->
                <Button x:Name="btn_create_worksets" Content="Create Worksets" Click="btn_create_worksets_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Create standard worksets from the workset list"/>
                <Button x:Name="btn_remove_unused" Content="Remove Unused" Click="btn_remove_unused_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Remove worksets not in the standard list"/>

                <Rectangle Width="1" Fill="#DCDCDC" Margin="8,2"/>

                <!-- Import / Export / Reset / Save -->
                <Button x:Name="btn_import" Content="Import" Click="btn_import_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Import rules from a JSON file (replaces current rules)"/>
                <Button x:Name="btn_export" Content="Export" Click="btn_export_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Export current rules to a JSON file"/>
                <Button x:Name="btn_reset" Content="Reset" Click="btn_reset_click"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Reset all rules to factory defaults"/>
                <Button x:Name="btn_save" Content="Save" Click="btn_save_click"
                        Background="#7F8C8D" Foreground="White" BorderBrush="#7F8C8D"
                        Padding="10,5" Margin="2" Cursor="Hand" FontSize="12"
                        ToolTip="Save rules to disk"/>
            </WrapPanel>
        </Border>

        <!-- ====== DATAGRID ====== -->
        <DataGrid x:Name="rules_grid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA"
                  Background="White"
                  BorderThickness="0"
                  RowHeight="30"
                  HeadersVisibility="Column"
                  CellEditEnding="grid_cell_edit_ending">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderBrush" Value="#2C3E50"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="Height" Value="34"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <!-- Run order -->
                <DataGridTextColumn Header="#" Binding="{Binding RunOrder}"
                                    Width="44" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#999"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Enabled checkbox -->
                <DataGridTemplateColumn Header="On" Width="46" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Rule Name -->
                <DataGridTextColumn Header="Rule Name"
                                    Binding="{Binding Name, Mode=TwoWay}" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Description -->
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, Mode=TwoWay}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="Foreground" Value="#666"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Category Filter -->
                <DataGridTextColumn Header="Category Filter"
                                    Binding="{Binding CategoryFilter, Mode=TwoWay}" Width="165">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Target Workset -->
                <DataGridTextColumn Header="Target Workset"
                                    Binding="{Binding Workset, Mode=TwoWay}" Width="235">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
