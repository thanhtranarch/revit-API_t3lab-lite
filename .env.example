# T3Lab Lite Extension Configuration
# Copy this file to ~/.t3lab/family_loader_config.json and update with your values

# Example configuration file (~/.t3lab/family_loader_config.json):
# {
#   "cloud_api_base": "https://your-deployment.vercel.app",
#   "cloud_api_endpoint": "/api/families",
#   "vercel_bypass_token": "your-bypass-token-here"
# }

# Security Note:
# DO NOT commit the actual config file with credentials to version control
# Keep your credentials in ~/.t3lab/family_loader_config.json (already in .gitignore)
