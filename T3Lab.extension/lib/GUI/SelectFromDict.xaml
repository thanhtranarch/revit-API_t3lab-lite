<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Select From Dict"
    Height="550" Width="400"
    MinWidth="400"
    MinHeight="550" MaxHeight="550"
    WindowStartupLocation="CenterScreen"
    HorizontalAlignment="Center"
    ShowInTaskbar="True"
    WindowStyle="None"
    Background="White"
    FontFamily="Segoe UI">

    <!--MAIN-->
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="45"/>
            <RowDefinition/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!--HEADER START (BatchOut style)-->
        <Grid MouseDown="header_drag" Background="#F8F9FA"
              BorderBrush="#BDC3C7" BorderThickness="0,0,0,1"
              Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="🔤" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="main_title" Text="Select"
                           FontWeight="SemiBold" Foreground="#2C3E50"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕" Grid.Column="1"
                    Width="30" Height="28" FontSize="11"
                    Click="button_close"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#7F8C8D" Cursor="Hand"
                    VerticalAlignment="Center" Margin="0,0,4,0"/>
        </Grid>
        <!--HEADER END-->



        <!--FILTER START-->
        <DockPanel Grid.Row="1">
            <Label  Content="🔍"
                    VerticalAlignment="Top" Height="26"
                    Foreground="#7F8C8D"
                    Margin="5,5,5,5"/>

            <TextBox x:Name="textbox_filter"
                    Text=""
                     Height="22" VerticalAlignment="Top"
                     Foreground="#7F8C8D" Background="White"
                     Margin="0,8,10,5" FontSize="14"
                     BorderBrush="#BDC3C7"
                     TextChanged="text_filter_updated">

                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </DockPanel>
        <!--FILTER END-->

        <!--LISTBOX START-->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Top"
                    Margin="10,5,10,5">

            <Separator Background="{StaticResource border_magenta}"/>

            <Label x:Name="text_label"  Content="Select Elements:"
                           Foreground="#7F8C8D"/>

            <ListBox x:Name="main_ListBox"
                         Height="350" Grid.Row="0"
                         Background="White"
                         SelectionMode="Single"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderBrush="#BDC3C7"
                         >

                <ListBox.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="{StaticResource border_magenta}"/>
                        <Setter Property="Foreground" Value="{StaticResource border_magenta}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource header_background}"/>
                        <Setter Property="Opacity" Value="0.9"/>
                        <Setter Property="Margin" Value="3"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                    <Grid x:Name="Bg"
                                              SnapsToDevicePixels="true">
                                        <Border BorderBrush     = "{TemplateBinding BorderBrush}"
                                                    BorderThickness = "{TemplateBinding BorderThickness}"
                                                    Background      = "{TemplateBinding Background}"

                                                    Grid.Row        = "1"
                                                    CornerRadius="10"/>

                                        <Track x:Name="PART_Track"
                                                   IsDirectionReversed="true"
                                                   IsEnabled="{TemplateBinding IsMouseOver}"
                                                   Grid.Row="1">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ScrollBarThumbVertical}"
                                                           Margin="2"/>
                                            </Track.Thumb>
                                        </Track>

                                    </Grid>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ListBox">
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox  Background="#EE82EE" Foreground="#2C3E50" IsChecked="{Binding IsChecked}"  Checked="UIe_ItemChecked" >
                            <TextBlock Text="{Binding Name}"/>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>


            </ListBox>

            <!--BUTTONS START-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" x:Name="UI_Buttons_all_none">
                <!--BUTTON_1-->
                <Button Content="Select All"
                        Click="button_select_all"
                        Height="20"
                        Width="100"
                        Margin="5"
                        />
                <!--BUTTON_2-->
                <Button Content="Select None"
                        Click="button_select_none"
                        Height="20"
                        Width="100"
                        Margin="5"
                        />
            </StackPanel>
            <!--BUTTONS END-->

            <!--BUTTON_2-->
            <Button x:Name="button_main"
                Content="Select"
                        Click="button_select"
                        Height="30"
                        Width="210"
                        Margin="5"
                        />

        </StackPanel>
        <!--LISTBOX END-->

        <!--FOOTER START-->
        <Border Grid.Row="3" Background="#F8F9FA"
                BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
            <TextBlock Text="© Copyright by T3Lab"
                       FontSize="10" Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        <!--FOOTER END-->
    </Grid>
</Window>